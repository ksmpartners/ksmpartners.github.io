---
interface Props {
  title: string;
  summary: string;
  slug: string;
  vertical: string;
  client?: string;
}

const { title, summary, slug, vertical, client } = Astro.props;
---
<article class="card">
  <div class="card-meta">
    <span class="tag">{vertical}</span>
    {client && <span> &mdash; {client}</span>}
  </div>
  <h3>{title}</h3>
  <p>{summary}</p>
  <a href={`case-studies/${slug}`} class="card-link">Read case study →</a>
</article>
