---
import PageLayout from '../layouts/PageLayout.astro';
---
<PageLayout title="Contact Us" description="Get in touch with KSM Technology Partners to discuss your project.">

  <div class="page-header">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Tell us about your project and we'll follow up within one business day.</p>
    </div>
  </div>

  <div class="section">
    <div style="display: grid; grid-template-columns: 1fr; gap: 3rem;">

      <!-- Form -->
      <div>
        <form
          action="https://formspree.io/f/xojndjkw"
          method="POST"
          class="contact-form"
        >
          <div class="form-group">
            <label for="name">Full Name <span aria-hidden="true">*</span></label>
            <input
              type="text"
              id="name"
              name="Full Name"
              required
              autocomplete="name"
              placeholder="Full Name"
            />
          </div>

          <div class="form-group">
            <label for="email">Email Address <span aria-hidden="true">*</span></label>
            <input
              type="email"
              id="email"
              name="Email Address"
              required
              autocomplete="email"
              placeholder="email@example.com"
            />
          </div>

          <div class="form-group">
            <label for="company">Company</label>
            <input
              type="text"
              id="company"
              name="Company"
              autocomplete="organization"
              placeholder="Company Name"
            />
          </div>

          <div class="form-group">
            <label for="message">Message <span aria-hidden="true">*</span></label>
            <textarea
              id="message"
              name="Message"
              required
              placeholder="Tell us about your project, timeline, and any specific questions you have..."
            ></textarea>
          </div>

          <div class="form-group form-group--checkbox">
            <input value="Agreed" type="checkbox" id="agreed-privacy" name="Agreed Privacy" required />
            <label for="agreed-privacy">I agree to the <a href="https://app.termly.io/document/terms-of-use-for-website/9f9fe9fa-edb2-48d2-992e-51a9e7883962" target="_blank" rel="noopener noreferrer">Terms &amp; Conditions</a> and <a href="https://app.termly.io/document/privacy-policy/0dea1a71-b5c4-49e4-b691-77c30ef7f1c7" target="_blank" rel="noopener noreferrer">Privacy Policy</a>. <span aria-hidden="true">*</span></label>
          </div>

          <button type="submit" id="submit-btn" class="btn" disabled>Send Message</button>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="prose">
        <h2>Drop Us a Line</h2>
        <p>
          We're based in the United States and work with clients throughout North America and internationally.
        </p>
        <p>
          Fill out the form at left and tell us how we can help you. Fields shown with an asterisk are required.
        </p>
        <p>
          <strong>Response time:</strong> We aim to respond to all inquiries within one business day.
        </p>
        <h3>What to Include</h3>
        <p>To help us give you a useful initial response, it helps to know:</p>
        <ul>
          <li>A brief description of the problem you're trying to solve</li>
          <li>Your industry (utilities, life sciences, or other)</li>
          <li>Rough timeline and urgency</li>
          <li>Whether you're looking for a long-term engagement or a specific project</li>
        </ul>
        <p>No pressure for details — even a brief note is fine as a starting point.</p>
      </div>

    </div>
  </div>

</PageLayout>

<script>
  const checkbox = document.getElementById('agreed-privacy') as HTMLInputElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  checkbox.addEventListener('change', () => {
    submitBtn.disabled = !checkbox.checked;
  });
</script>

<style>
  .btn:disabled {
    background: #aaa;
    border-color: #aaa;
    color: #fff;
    cursor: not-allowed;
  }
  .form-group--checkbox {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.95rem;
  }

  .form-group--checkbox input[type="checkbox"] {
    width: auto;
    flex-shrink: 0;
    margin: 0;
    cursor: pointer;
  }

  .form-group--checkbox label {
    display: inline;
    font-weight: normal;
    margin: 0;
    cursor: pointer;
  }

  @media (min-width: 768px) {
    .section > div {
      grid-template-columns: 3fr 2fr !important;
    }
  }
</style>
